DATABASE_URL=postgresql+psycopg2://qubitx_user:change-me@postgres:5432/qubitx
REDIS_URL=redis://redis:6379/2
REDIS_QUEUE_PREFIX=qubitx

ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_ACCESS_TOKEN=
ZERODHA_REDIRECT_URL=
ZERODHA_LIVE_TRADING_ENABLED=false
PAPER_TRADING_ENABLED=true

DAILY_SCAN_TIME=15:45
MARKET_TIMEZONE=Asia/Kolkata
BUY_VOLUME_MULTIPLIER=5
SELL_VOLUME_MULTIPLIER=3
ENTRY_BUFFER_TICKS=0.05
STOP_BUFFER_TICKS=0.05

DAILY_CANDLE_LOOKBACK=100
SWING_WINDOW=2
MAX_GAP_PERCENT=0.5
MIN_SWING_DISTANCE=1.0

API_HOST_PORT=8095
API_HOST_BIND=127.0.0.1
LOG_LEVEL=INFO
WORKER_POLL_TIMEOUT=5
WORKER_MAX_RETRIES=3
SCHEDULER_POLL_INTERVAL_SECONDS=30
RECONCILIATION_POLL_INTERVAL_SECONDS=300

JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=720
SESSION_COOKIE_NAME=qubitx_session
SESSION_COOKIE_SECURE=false
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me
INITIAL_ADMIN_NAME=Platform Administrator
TOTP_ISSUER=Qubitx Control Center

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
MOCK_DATA=false
