APP_PORT=8095
WEBHOOK_SECRET=change-me
DATABASE_URL=postgresql+psycopg2://trading_user:password@postgres:5432/trading_db
REDIS_URL=redis://redis:6379/2
JWT_SECRET=replace-with-a-long-random-secret
SIGNAL_QUEUE_NAME=trading_signals_queue
MOCK_DATA=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
APP_HOST_BIND=0.0.0.0
LOG_LEVEL=INFO
ACCESS_TOKEN_EXPIRE_MINUTES=720
SESSION_COOKIE_NAME=trading_session
SESSION_COOKIE_SECURE=false
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me
INITIAL_ADMIN_NAME=Platform Administrator
TOTP_ISSUER=AlgoTrade Control Center

# Future strategy tuning
STRATEGY_TUNING__LOOKBACKCANDLES=20
STRATEGY_TUNING__MAXGAPPERCENT=0.5
STRATEGY_TUNING__MINSWINGDISTANCE=1.0
STRATEGY_TUNING__BUYVOLUMEMULTIPLIER=1.0
STRATEGY_TUNING__SELLVOLUMEMULTIPLIER=1.0
STRATEGY_TUNING__ENTRYBUFFERTICKS=0.05
STRATEGY_TUNING__STOPLOSSBUFFERTICKS=0.05
